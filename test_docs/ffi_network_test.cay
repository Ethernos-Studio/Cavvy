// FFI 网络功能测试
// 测试 Network.cay 中的基本功能

#include <Network.cay>

public int main() {
    // 初始化网络库
    if (!NetworkUtils.init()) {
        println("Failed to initialize network library");
        return 1;
    }
    
    // 测试 SocketAddr 创建
    SocketAddr addr = new SocketAddr().fromString("127.0.0.1", 8080);
    println("SocketAddr created for 127.0.0.1:8080");
    
    // 测试 localhost 地址创建
    SocketAddr localAddr = new SocketAddr().localhost(9090);
    println("Localhost address created for port 9090");
    
    // 测试通配地址创建
    SocketAddr anyAddr = new SocketAddr().any(7070);
    println("Wildcard address created for port 7070");
    
    // 测试端口号获取
    int port = addr.getPort();
    println("Port extracted: " + (String)port);
    
    // 测试网络字节序转换
    int hostPort = 8080;
    int netPort = NetworkUtils.htons(hostPort);
    int hostPortBack = NetworkUtils.ntohs(netPort);
    
    if (hostPort == hostPortBack) {
        println("hton/ntoh conversion test passed");
    } else {
        println("hton/ntoh conversion test failed");
        return 1;
    }
    
    // 测试32位字节序转换
    int hostLong = 0x12345678;
    int netLong = NetworkUtils.htonl(hostLong);
    int hostLongBack = NetworkUtils.ntohl(netLong);
    
    if (hostLong == hostLongBack) {
        println("htonl/ntohl conversion test passed");
    } else {
        println("htonl/ntohl conversion test failed");
        return 1;
    }
    
    // 测试 TcpSocket 创建（不实际连接）
    TcpSocket socket = new TcpSocket();
    println("TcpSocket created successfully");
    
    // 关闭 socket
    socket.close();
    println("TcpSocket closed successfully");
    
    // 测试 UdpSocket 创建
    UdpSocket udpSocket = new UdpSocket();
    println("UdpSocket created successfully");
    
    // 关闭 UDP socket
    udpSocket.close();
    println("UdpSocket closed successfully");
    
    // 清理网络库
    NetworkUtils.cleanup();
    println("Network library cleaned up");
    
    println("All network FFI tests passed!");
    return 0;
}
