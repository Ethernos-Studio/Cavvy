/**
 * Math库综合测试
 * 测试Math标准库的所有功能
 * 
 * 版本: 0.5.3.1
 */

#include <Math.cay>

@main
public class MathTest {
    public static int main(String[] args) {
        println("=== Math Library Test Suite ===");
        
        // 测试三角函数
        println("\n--- Trigonometric Functions ---");
        double pi = MATH_PI;
        println("sin(0) = " + (String)Math.sin(0.0));
        println("sin(π/2) = " + (String)Math.sin(pi / 2.0));
        println("cos(0) = " + (String)Math.cos(0.0));
        println("cos(π) = " + (String)Math.cos(pi));
        println("tan(π/4) = " + (String)Math.tan(pi / 4.0));
        
        // 测试反三角函数
        println("\n--- Inverse Trigonometric Functions ---");
        println("asin(0) = " + (String)Math.asin(0.0));
        println("asin(1) = " + (String)Math.asin(1.0));
        println("acos(1) = " + (String)Math.acos(1.0));
        println("atan(1) = " + (String)Math.atan(1.0));
        println("atan2(1, 1) = " + (String)Math.atan2(1.0, 1.0));
        
        // 测试双曲函数
        println("\n--- Hyperbolic Functions ---");
        println("sinh(0) = " + (String)Math.sinh(0.0));
        println("cosh(0) = " + (String)Math.cosh(0.0));
        println("tanh(0) = " + (String)Math.tanh(0.0));
        
        // 测试指数和对数
        println("\n--- Exponential and Logarithmic ---");
        println("exp(1) = " + (String)Math.exp(1.0));
        println("log(E) = " + (String)Math.log(MATH_E));
        println("log10(100) = " + (String)Math.log10(100.0));
        println("log2(8) = " + (String)Math.log2(8.0));
        println("logBase(8, 2) = " + (String)Math.logBase(8.0, 2.0));
        
        // 测试幂函数
        println("\n--- Power Functions ---");
        println("pow(2, 10) = " + (String)Math.pow(2.0, 10.0));
        println("sqrt(16) = " + (String)Math.sqrt(16.0));
        println("cbrt(27) = " + (String)Math.cbrt(27.0));
        println("cbrt(-8) = " + (String)Math.cbrt(-8.0));
        println("sqr(5) = " + (String)Math.sqr(5.0));
        
        // 测试取整函数
        println("\n--- Rounding Functions ---");
        println("ceil(2.3) = " + (String)Math.ceil(2.3));
        println("floor(2.7) = " + (String)Math.floor(2.7));
        println("round(2.5) = " + (String)Math.round(2.5));
        println("trunc(-2.7) = " + (String)Math.trunc(-2.7));
        println("frac(3.14) = " + (String)Math.frac(3.14));
        println("frac(-3.14) = " + (String)Math.frac(-3.14));
        
        // 测试绝对值
        println("\n--- Absolute Value ---");
        println("abs(-5.5) = " + (String)Math.abs(-5.5));
        println("abs(-10) = " + (String)Math.abs(-10));
        println("abs(MATH_MIN_INT) = " + (String)Math.abs(MATH_MIN_INT));
        println("abs(-100L) = " + (String)Math.abs(-100L));
        
        // 测试符号函数
        println("\n--- Sign Function ---");
        println("sign(-5.5) = " + (String)Math.sign(-5.5));
        println("sign(0) = " + (String)Math.sign(0.0));
        println("sign(3.14) = " + (String)Math.sign(3.14));
        
        // 测试最值函数
        println("\n--- Min/Max Functions ---");
        println("max(3, 5) = " + (String)Math.max(3, 5));
        println("min(3.5, 2.5) = " + (String)Math.min(3.5, 2.5));
        println("max(100L, 200L) = " + (String)Math.max(100L, 200L));
        
        // 测试钳制函数
        println("\n--- Clamp Function ---");
        println("clamp(15, 0, 10) = " + (String)Math.clamp(15, 0, 10));
        println("clamp(-5, 0, 10) = " + (String)Math.clamp(-5, 0, 10));
        println("clamp(5, 0, 10) = " + (String)Math.clamp(5, 0, 10));
        // 测试min > max自动交换
        println("clamp(5, 10, 0) = " + (String)Math.clamp(5, 10, 0));
        
        // 测试近似相等
        println("\n--- Approximate Equal ---");
        println("approxEqual(1.0, 1.0000000001) = " + (String)Math.approxEqual(1.0, 1.0000000001));
        println("approxEqual(1.0, 1.1) = " + (String)Math.approxEqual(1.0, 1.1));
        println("approxEqualRelative(1e9, 1e9+1, 1e-10) = " + (String)Math.approxEqualRelative(1e9, 1e9+1, 1e-10));
        
        // 测试插值函数
        println("\n--- Interpolation ---");
        println("lerp(0, 10, 0.5) = " + (String)Math.lerp(0.0, 10.0, 0.5));
        println("lerp(0, 100, 0.25) = " + (String)Math.lerp(0, 100, 0.25));
        println("smoothStep(0, 1, 0.5) = " + (String)Math.smoothStep(0.0, 1.0, 0.5));
        // 测试a == b情况
        println("smoothStep(5, 5, 0.5) = " + (String)Math.smoothStep(5.0, 5.0, 0.5));
        
        // 测试GCD和LCM
        println("\n--- GCD and LCM ---");
        println("gcd(48, 18) = " + (String)Math.gcd(48, 18));
        println("gcd(-48, 18) = " + (String)Math.gcd(-48, 18));
        println("gcd(MATH_MIN_INT, 1) = " + (String)Math.gcd(MATH_MIN_INT, 1));
        println("lcm(4, 6) = " + (String)Math.lcm(4, 6));
        
        // 测试角度转换
        println("\n--- Angle Conversion ---");
        println("toRadians(180) = " + (String)Math.toRadians(180.0));
        println("toDegrees(π) = " + (String)Math.toDegrees(pi));
        
        println("\n=== All Math Tests Passed! ===");
        return 0;
    }
}
