/**
 * Extern别名功能测试
 * 测试extern函数别名功能
 * 
 * 版本: 0.5.3.1
 */

#include <std/ffi.cay>

// 使用别名的extern声明
extern {
    c_double sin(c_double x) as c_sin;
    c_double cos(c_double x) as c_cos;
    c_double sqrt(c_double x) as c_sqrt;
    c_int rand() as c_rand;
    void srand(c_uint seed) as c_srand;
    c_int64_t time(c_int64_t* timer) as c_time;
}

@main
public class ExternAliasTest {
    public static int main(String[] args) {
    println("=== Extern Alias Test Suite ===");
    
    // 测试通过别名调用C函数
    println("\n--- Calling aliased extern functions ---");
    
    // 测试c_sin
    double result1 = (double)c_sin((c_double)0.0);
    println("c_sin(0) = " + (String)result1);
    if (!((result1 >= -0.001) && (result1 <= 0.001))) {
        println("ERROR: c_sin(0) should be 0");
        return 1;
    }
    
    // 测试c_cos
    double result2 = (double)c_cos((c_double)0.0);
    println("c_cos(0) = " + (String)result2);
    if (!((result2 >= 0.999) && (result2 <= 1.001))) {
        println("ERROR: c_cos(0) should be 1");
        return 1;
    }
    
    // 测试c_sqrt
    double result3 = (double)c_sqrt((c_double)16.0);
    println("c_sqrt(16) = " + (String)result3);
    if (result3 != 4.0) {
        println("ERROR: c_sqrt(16) should be 4");
        return 1;
    }
    
    // 测试随机数函数
    println("\n--- Random functions with alias ---");
    c_srand((c_uint)12345);
    int r1 = c_rand();
    int r2 = c_rand();
    println("c_rand() #1 = " + (String)r1);
    println("c_rand() #2 = " + (String)r2);
    
    // 验证随机数在合理范围内
    if (r1 < 0 || r1 > 2147483647) {
        println("ERROR: c_rand() returned out of range value");
        return 1;
    }
    
    // 验证两次调用返回不同值（大概率）
    if (r1 == r2) {
        println("WARNING: Two consecutive c_rand() calls returned same value");
    }
    
    // 测试时间函数
    println("\n--- Time function with alias ---");
    long t = (long)c_time(0);
    println("c_time(0) = " + (String)t);
    if (t <= 0) {
        println("ERROR: c_time() should return positive value");
        return 1;
    }
    
    // 测试组合使用
    println("\n--- Combined usage ---");
    c_int64_t time_val = c_time(0);
    int angle_int = (int)(time_val % 360);
    double angle = (double)angle_int;
    double radians = angle * 3.14159265359 / 180.0;
    double s = (double)c_sin((c_double)radians);
    double c = (double)c_cos((c_double)radians);
    double sumSq = s * s + c * c;
    println("sin(" + (String)angle + "°)^2 + cos(" + (String)angle + "°)^2 = " + (String)sumSq);
    // 验证 sin^2 + cos^2 = 1
    if (!((sumSq >= 0.999) && (sumSq <= 1.001))) {
        println("ERROR: sin^2 + cos^2 should be 1");
        return 1;
    }
    
    println("\n=== All Extern Alias Tests Passed! ===");
    println("Note: Original function names (sin, cos, sqrt, etc.) are NOT accessible");
    println("Only the aliased names (c_sin, c_cos, c_sqrt, etc.) can be used");
    return 0;
    }
}
