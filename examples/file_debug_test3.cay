/**
 * File.cay 调试测试3 - 详细诊断
 */

#include <std/ffi.cay>
#include <File.cay>

public class DebugTest3 {
    
    public static int main() {
        println("=== File.cay 调试测试3 ===\n");
        
        // 手动模拟静态方法 writeAllText
        println("手动模拟静态方法 writeAllText:");
        
        File file = new File();
        println("1. 创建File对象");
        
        FileMode mode = FileMode.write();
        println("2. 获取FileMode: '" + mode.getMode() + "'");
        
        String path = "test_manual.txt";
        println("3. 路径: '" + path + "'");
        
        bool opened = file.open(path, mode);
        println("4. 打开结果: " + opened);
        println("   isOpen: " + file.isOpened());
        
        if (opened) {
            String content = "Test content";
            println("5. 内容: '" + content + "'");
            println("   内容长度: " + content.length());
            println("   内容是否为null: " + (content == null));
            
            println("6. 调用 writeAllText...");
            bool written = file.writeAllText(content);
            println("   写入结果: " + written);
            
            println("7. 关闭文件...");
            file.close();
            println("   已关闭");
        }
        
        // 检查文件是否存在
        println("\n检查文件是否存在:");
        bool exists = File.exists("test_manual.txt");
        println("test_manual.txt 存在: " + exists);
        
        // 尝试读取
        if (exists) {
            println("\n尝试读取文件:");
            File readFile = new File();
            if (readFile.open("test_manual.txt", FileMode.read())) {
                String content = readFile.readAllText();
                println("读取内容: '" + content + "'");
                readFile.close();
            }
        }
        
        // 清理
        File.delete("test_manual.txt");
        
        println("\n=== 测试完成 ===");
        return 0;
    }
}
