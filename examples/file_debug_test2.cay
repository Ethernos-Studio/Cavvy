/**
 * File.cay 调试测试2 - 测试 writeAllText
 */

#include <std/ffi.cay>
#include <File.cay>

public class DebugTest2 {
    
    public static int main() {
        println("=== File.cay 调试测试2 ===\n");
        
        // 测试实例方法 writeAllText
        println("测试: 实例方法 writeAllText");
        File file = new File();
        
        println("打开文件...");
        bool opened = file.open("test_write2.txt", FileMode.write());
        println("打开结果: " + opened);
        
        if (opened) {
            println("调用 writeAllText...");
            bool written = file.writeAllText("Hello from writeAllText!");
            println("writeAllText 结果: " + written);
            file.close();
            println("文件已关闭");
            
            // 读取验证
            println("\n读取验证:");
            File readFile = new File();
            if (readFile.open("test_write2.txt", FileMode.read())) {
                String content = readFile.readAllText();
                println("读取内容: '" + content + "'");
                readFile.close();
            }
        }
        
        // 测试静态方法 writeAllText
        println("\n测试: 静态方法 writeAllText");
        bool staticWritten = File.writeAllText("test_static.txt", "Hello from static!");
        println("静态 writeAllText 结果: " + staticWritten);
        
        if (staticWritten) {
            println("静态写入成功，读取验证:");
            String content = File.readAllText("test_static.txt");
            println("读取内容: '" + content + "'");
        }
        
        // 清理
        println("\n清理...");
        File.delete("test_write2.txt");
        File.delete("test_static.txt");
        
        println("\n=== 测试完成 ===");
        return 0;
    }
}
