// 内联IR复杂表达式测试
// 测试复合表达式和计算

public class TestInlineIrComplex {
    
    // 测试复合算术表达式: (a + b) * (c - d)
    public static int testComplexExpr(int a, int b, int c, int d) {
        int result;
        __ir {
            ; 计算 a + b
            %sum = add i32 %a, %b
            
            ; 计算 c - d
            %diff = sub i32 %c, %d
            
            ; 相乘
            %prod = mul i32 %sum, %diff
            
            store i32 %prod, i32* %result
        }
        return result;
    }
    
    // 测试多项式计算: a*x^2 + b*x + c
    public static int testPolynomial(int a, int b, int c, int x) {
        int result;
        __ir {
            ; 计算 x^2
            %x2 = mul i32 %x, %x
            
            ; 计算 a*x^2
            %ax2 = mul i32 %a, %x2
            
            ; 计算 b*x
            %bx = mul i32 %b, %x
            
            ; 计算 a*x^2 + b*x
            %ax2_bx = add i32 %ax2, %bx
            
            ; 加上 c
            %final = add i32 %ax2_bx, %c
            
            store i32 %final, i32* %result
        }
        return result;
    }
    
    // 测试绝对值计算
    public static int testAbs(int a) {
        int result;
        __ir {
            ; 检查是否小于0
            %isNeg = icmp slt i32 %a, 0
            
            ; 如果是负数，取反
            %negA = sub i32 0, %a
            %absVal = select i1 %isNeg, i32 %negA, i32 %a
            
            store i32 %absVal, i32* %result
        }
        return result;
    }
    
    // 测试最大值
    public static int testMax(int a, int b) {
        int result;
        __ir {
            ; 比较 a > b
            %isGreater = icmp sgt i32 %a, %b
            
            ; 选择较大的值
            %maxVal = select i1 %isGreater, i32 %a, i32 %b
            
            store i32 %maxVal, i32* %result
        }
        return result;
    }
    
    // 测试最小值
    public static int testMin(int a, int b) {
        int result;
        __ir {
            ; 比较 a < b
            %isLess = icmp slt i32 %a, %b
            
            ; 选择较小的值
            %minVal = select i1 %isLess, i32 %a, i32 %b
            
            store i32 %minVal, i32* %result
        }
        return result;
    }
    
    public static void main() {
        // 测试复合表达式 (2+3)*(5-1) = 5*4 = 20
        int complex = testComplexExpr(2, 3, 5, 1);
        println("(2+3)*(5-1) = " + complex + " (expected 20)");
        
        // 测试多项式: 2*x^2 + 3*x + 4, x=2 => 8+6+4 = 18
        int poly = testPolynomial(2, 3, 4, 2);
        println("2*2^2 + 3*2 + 4 = " + poly + " (expected 18)");
        
        // 测试绝对值
        int absNeg = testAbs(-42);
        int absPos = testAbs(42);
        println("Abs(-42) = " + absNeg + " (expected 42)");
        println("Abs(42) = " + absPos + " (expected 42)");
        
        // 测试最大值和最小值
        int maxVal = testMax(10, 5);
        int minVal = testMin(10, 5);
        println("Max(10, 5) = " + maxVal + " (expected 10)");
        println("Min(10, 5) = " + minVal + " (expected 5)");
        
        // 验证
        if (complex == 20 && poly == 18 && absNeg == 42 && absPos == 42 &&
            maxVal == 10 && minVal == 5) {
            println("\nAll complex tests passed!");
        } else {
            println("\nSome tests failed!");
        }
    }
}
