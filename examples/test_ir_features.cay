// test_ir_features.cay - 验证 IR 模块生产可用性的综合测试程序
// 覆盖: 变量声明、控制流、表达式、数组、类、方法重载、静态成员、顶层函数

// ============================================================
// 顶层函数 - 测试 IR Builder 的顶层函数支持
// ============================================================
public int add(int a, int b) {
    return a + b;
}

public int multiply(int a, int b) {
    return a * b;
}

// ============================================================
// 接口定义 - 测试 IR Builder 的接口处理
// ============================================================
public interface Calculator {
    int compute(int x, int y);
    void reset();
}

// ============================================================
// 基类 - 测试 IR Builder 的继承/构造函数
// ============================================================
public class BaseMath {
    protected int baseValue;
    
    public BaseMath(int val) {
        baseValue = val;
    }
    
    public int getBase() {
        return baseValue;
    }
}

// ============================================================
// 主实现类 - 综合测试所有 IR 特性
// ============================================================
public class IRTest extends BaseMath implements Calculator {
    private int result;
    private static int instanceCount = 0;
    
    public IRTest(int val) {
        super(val);
        result = 0;
        instanceCount = instanceCount + 1;
    }
    
    // 接口方法实现
    public int compute(int x, int y) {
        return x + y + baseValue;
    }
    
    public void reset() {
        result = 0;
    }
    
    // === 变量声明测试 ===
    public void testVarDecl() {
        int i = 42;
        long l = 100L;
        float f = 3.14f;
        double d = 3.14159;
        boolean b = true;
        char c = 'A';
        
        // auto 类型推断
        auto ai = 100;
        auto af = 2.5;
        auto ab = false;
    }
    
    // === 控制流: if/else 测试 ===
    public int testIfElse(int x) {
        if (x > 10) {
            return 1;
        } else if (x > 5) {
            return 2;
        } else {
            return 3;
        }
    }
    
    // === 控制流: while 测试 ===
    public int testWhile(int n) {
        int sum = 0;
        int i = 0;
        while (i < n) {
            sum = sum + i;
            i = i + 1;
        }
        return sum;
    }
    
    // === 控制流: for 测试 ===
    public int testFor(int n) {
        int prod = 1;
        for (int i = 1; i <= n; i++) {
            prod = prod * i;
        }
        return prod;
    }
    
    // === 控制流: do-while 测试 ===
    public int testDoWhile(int n) {
        int count = 0;
        do {
            count = count + 1;
            n = n - 1;
        } while (n > 0);
        return count;
    }
    
    // === 控制流: break/continue 测试 ===
    public int testBreakContinue(int limit) {
        int sum = 0;
        for (int i = 0; i < 100; i++) {
            if (i >= limit) {
                break;
            }
            if (i % 2 == 0) {
                continue;
            }
            sum = sum + i;
        }
        return sum;
    }
    
    // === 控制流: switch 测试 ===
    public int testSwitch(int value) {
        int result = 0;
        switch (value) {
            case 1:
                result = 10;
                break;
            case 2:
                result = 20;
                break;
            case 3:
                result = 30;
                break;
            default:
                result = 0;
                break;
        }
        return result;
    }
    
    // === 控制流: 三元运算符测试 ===
    public int testTernary(int a, int b) {
        int max = a > b ? a : b;
        return max;
    }
    
    // === 算术表达式测试 ===
    public int testArithmetic(int a, int b) {
        int sum = a + b;
        int diff = a - b;
        int prod = a * b;
        int quot = a / b;
        int mod = a % b;
        return sum + diff + prod + quot + mod;
    }
    
    // === 比较和逻辑表达式测试 ===
    public boolean testComparisons(int a, int b) {
        boolean eq = a == b;
        boolean ne = a != b;
        boolean lt = a < b;
        boolean gt = a > b;
        boolean le = a <= b;
        boolean ge = a >= b;
        boolean logicalAnd = eq && lt;
        boolean logicalOr = gt || le;
        boolean logicalNot = !eq;
        return logicalAnd || logicalOr || logicalNot;
    }
    
    // === 位运算测试 ===
    public int testBitwise(int a, int b) {
        int and = a & b;
        int or = a | b;
        int xor = a ^ b;
        int shiftLeft = a << 2;
        int shiftRight = a >> 1;
        return and + or + xor + shiftLeft + shiftRight;
    }
    
    // === 类型转换测试 ===
    public int testCasting(double d) {
        int i = (int)d;
        long l = (long)d;
        float f = (float)d;
        double dd = (double)i;
        return i;
    }
    
    // === 自增自减测试 ===
    public int testIncDec(int x) {
        int a = x;
        a++;
        a--;
        ++a;
        --a;
        return a;
    }
    
    // === 复合赋值测试 ===
    public int testCompoundAssign(int x) {
        int val = 10;
        val += x;
        val -= 2;
        val *= 3;
        val /= 5;
        val %= 4;
        return val;
    }
    
    // === 数组创建和访问测试 ===
    public int testArray() {
        int[] arr = new int[5];
        arr[0] = 10;
        arr[1] = 20;
        arr[2] = 30;
        arr[3] = 40;
        arr[4] = 50;
        
        int sum = 0;
        for (int i = 0; i < arr.length; i++) {
            sum = sum + arr[i];
        }
        return sum;
    }
    
    // === 数组初始化测试 ===
    public int testArrayInit() {
        int[] arr = {1, 2, 3, 4, 5};
        int prod = 1;
        for (int i = 0; i < 5; i++) {
            prod = prod * arr[i];
        }
        return prod;
    }
    
    // === 多维数组测试 ===
    public int testMultiDimArray() {
        int[][] matrix = new int[3][3];
        int val = 1;
        for (int i = 0; i < 3; i++) {
            for (int j = 0; j < 3; j++) {
                matrix[i][j] = val;
                val = val + 1;
            }
        }
        
        int sum = 0;
        for (int i = 0; i < 3; i++) {
            for (int j = 0; j < 3; j++) {
                sum = sum + matrix[i][j];
            }
        }
        return sum;
    }
    
    // === 字符串操作测试 ===
    public void testString() {
        String s = "Hello";
        int len = s.length();
        String sub = s.substring(0, 3);
        char ch = s.charAt(1);
    }
    
    // === 静态成员测试 ===
    public static int getInstanceCount() {
        return instanceCount;
    }
    
    // === 方法重载测试 ===
    public int overloaded(int a) {
        return a;
    }
    
    public int overloaded(int a, int b) {
        return a + b;
    }
    
    public double overloaded(double a, double b) {
        return a + b;
    }
    
    // === 主测试入口 ===
    public static void main() {
        IRTest test = new IRTest(10);
        
        // 运行所有测试
        test.testVarDecl();
        int ifResult = test.testIfElse(8);
        int whileResult = test.testWhile(10);
        int forResult = test.testFor(5);
        int doWhileResult = test.testDoWhile(5);
        int bcResult = test.testBreakContinue(10);
        int switchResult = test.testSwitch(2);
        int ternaryResult = test.testTernary(5, 8);
        int arithResult = test.testArithmetic(10, 3);
        boolean compResult = test.testComparisons(5, 10);
        int bitResult = test.testBitwise(6, 3);
        int castResult = test.testCasting(3.14);
        int incResult = test.testIncDec(5);
        int compAssignResult = test.testCompoundAssign(3);
        int arraySum = test.testArray();
        int arrayProd = test.testArrayInit();
        int matrixSum = test.testMultiDimArray();
        test.testString();
        
        // 测试重载
        int ol1 = test.overloaded(5);
        int ol2 = test.overloaded(3, 7);
        double ol3 = test.overloaded(2.5, 3.5);
        
        int count = IRTest.getInstanceCount();
        
        println("All IR feature tests completed successfully!");
        println("ifElse: " + ifResult);
        println("while: " + whileResult);
        println("for factorial: " + forResult);
        println("doWhile: " + doWhileResult);
        println("breakContinue: " + bcResult);
        println("switch: " + switchResult);
        println("ternary: " + ternaryResult);
        println("arraySum: " + arraySum);
        println("arrayProd: " + arrayProd);
        println("matrixSum: " + matrixSum);
        println("instanceCount: " + count);
    }
}
