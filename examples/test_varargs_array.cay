/**
 * 测试直接传递数组给可变参数
 */
public class TestVarargsArray {
    // 可变参数方法
    public static int sum(int... numbers) {
        int total = 0;
        for (int i = 0; i < numbers.length(); i++) {
            total = total + numbers[i];
        }
        return total;
    }

    public static void main() {
        println("Testing passing array to varargs:");

        // 方式1：直接传递多个参数（已支持）
        int result1 = sum(1, 2, 3, 4, 5);
        print("sum(1,2,3,4,5) = ");
        println(result1);

        // 方式2：直接传递数组（需要验证）
        int[] arr = new int[5]();
        arr[0] = 10;
        arr[1] = 20;
        arr[2] = 30;
        arr[3] = 40;
        arr[4] = 50;
        
        int result2 = sum(arr);
        print("sum([10,20,30,40,50]) = ");
        println(result2);

        println("All tests completed!");
    }
}
